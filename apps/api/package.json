{
  "name": "@dineflow/api",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./overlord-app": {
      "types": "./src/overlord-app.ts",
      "default": "./dist/overlord-app.js"
    },
    "./restaurant-app": {
      "types": "./src/restaurant-app.ts",
      "default": "./dist/restaurant-app.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.node.ts",
    "dev:cf": "wrangler dev",
    "build": "tsc -p tsconfig.declarations.json",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "gen-types": "tsc -p tsconfig.declarations.json",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run"
  },
  "dependencies": {
    "@dineflow/db": "workspace:*",
    "@dineflow/shared": "workspace:*",
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.4.3",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.2",
    "redis": "^5.12.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "wrangler": "^3.101.0",
    "typescript": "^5.7.2"
  }
}
