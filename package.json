{
  "name": "dineflow",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d redis",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "infra:logs": "docker compose -f docker/docker-compose.yml logs -f redis",
    "db:generate": "turbo run db:generate --filter=@dineflow/db",
    "db:migrate": "turbo run db:migrate --filter=@dineflow/db",
    "db:studio": "turbo run db:studio --filter=@dineflow/db",
    "db:seed": "turbo run db:seed --filter=@dineflow/db",
    "db:seed:superadmin": "turbo run db:seed:superadmin --filter=@dineflow/db",
    "deploy:api": "turbo run deploy --filter=@dineflow/api",
    "deploy:portal": "turbo run deploy --filter=@dineflow/portal",
    "deploy:menu": "turbo run deploy --filter=@dineflow/menu",
    "deploy:overlord": "turbo run deploy --filter=@dineflow/overlord",
    "deploy:all": "turbo run deploy --filter=@dineflow/api --filter=@dineflow/portal --filter=@dineflow/menu --filter=@dineflow/overlord"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.4.2",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2"
  }
}
