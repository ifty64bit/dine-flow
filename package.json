{
  "name": "dineflow",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d db redis",
    "infra:down": "docker compose -f docker/docker-compose.yml down",
    "infra:logs": "docker compose -f docker/docker-compose.yml logs -f db redis",
    "db:generate": "turbo run db:generate --filter=@dineflow/db",
    "db:migrate": "turbo run db:migrate --filter=@dineflow/db",
    "db:studio": "turbo run db:studio --filter=@dineflow/db",
    "db:seed": "turbo run db:seed --filter=@dineflow/db",
    "db:seed:superadmin": "turbo run db:seed:superadmin --filter=@dineflow/db"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "turbo": "^2.9.6",
    "typescript": "^5.7.2"
  }
}
