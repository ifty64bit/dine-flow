{
  "name": "dineflow",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@dineflow/db",
    "db:migrate": "turbo run db:migrate --filter=@dineflow/db",
    "db:studio": "turbo run db:studio --filter=@dineflow/db",
    "db:seed": "turbo run db:seed --filter=@dineflow/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2"
  }
}
